#!/usr/bin/env bash

set -o errexit
set -o pipefail
set -o nounset
# set -o xtrace

REPO_ROOT="$(git rev-parse --show-toplevel)"

STAGED_CPP="$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '^src/rookie_pico/.*\.(c|cpp|h|hpp)$' || true)"

STAGED_SH="$(git diff --cached --name-only --diff-filter=ACM \
    | grep -vE '^src/(rookie_pico/external|pico_interface/nanopb)/' \
    | grep -E '(\.sh$|^rookie$)' || true)"

function check_clang_format()
{
    [[ -z "${STAGED_CPP}" ]] && return 0

    if ! command -v clang-format &>/dev/null; then
        echo "ERR: clang-format not found, install it to use this hook"
        return 1
    fi

    local failed=0

    while IFS= read -r file; do
        if ! clang-format --dry-run --Werror "${REPO_ROOT}/${file}" 2>/dev/null; then
            echo "  needs formatting: ${file}"
            failed=1
        fi
    done <<< "${STAGED_CPP}"

    if [[ "${failed}" -ne 0 ]]; then
        echo ""
        echo "Fix with:"
        echo "  git diff --cached --name-only | grep -E '\\.(c|cpp|h|hpp)\$' | xargs clang-format -i"
        return 1
    fi
}

function check_shellcheck()
{
    [[ -z "${STAGED_SH}" ]] && return 0

    if ! command -v shellcheck &>/dev/null; then
        echo "ERR: shellcheck not found, install it to use this hook"
        return 1
    fi

    local failed=0

    while IFS= read -r file; do
        if ! shellcheck "${REPO_ROOT}/${file}"; then
            failed=1
        fi
    done <<< "${STAGED_SH}"

    [[ "${failed}" -ne 0 ]] && return 1
    return 0
}

function check_clang_tidy()
{
    [[ -z "${STAGED_CPP}" ]] && return 0

    if ! command -v clang-tidy &>/dev/null; then
        echo "ERR: clang-tidy not found, install to use this hook"
        return 1
    fi

    local failed=0
    while IFS= read -r file; do
        if ! clang-tidy \
            -p "${REPO_ROOT:?}/src/build/pico" \
            --quiet \
            "${REPO_ROOT}/${file}"; then
            failed=1
        fi
    done <<< "${STAGED_CPP}"

    return ${failed}
}

FAILED=0

echo "* Checking clang-format on staged rookie_pico files"
check_clang_format || FAILED=1

echo "* Checking shellcheck on staged shell scripts"
check_shellcheck || FAILED=1

echo "* Checking clang-tidy on staged rookie_pico .cpp files"
check_clang_tidy || FAILED=1

if [[ "${FAILED}" -ne 0 ]]; then
    echo ""
    echo "ERR: pre-commit checks failed - commit aborted"
    exit 1
fi
