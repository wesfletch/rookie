#!/usr/bin/env bash

set -o errexit
set -o pipefail
set -o nounset
# set -o xtrace

SCRIPT_DIR="$(dirname "$(readlink -f -- "${BASH_SOURCE[0]}")")"

COMMAND="run_container"
DUMP=0
NO_CACHE=0
ROS_DISTRO="jazzy"

USERNAME="${USER:-ubuntu}"

CONTAINER_IMG="rookie"
CONTAINER_NAME="rookie-dev"


function usage()
{
    cat <<EOF
Usage: $(basename "$0") <command> [options]

Commands:
    setup                       Setup the development environment, e.g., git hooks, etc.
    build, build-container      Build the Docker image for development
    run, run-container          Run a container from the image

Options:
    --dump, --dump-command      Print the docker command instead of executing
    -i, --image <name>          Set container image name (default: ${CONTAINER_IMG})
    -n, --name <name>           Set container name (default: ${CONTAINER_NAME})
    --no-cache                  Disable Docker build cache
    --ros, --ros-distro <distro>
                                Set ROS distro (default: ${ROS_DISTRO})

General:
    -h, --help                  Show this help message and exit

Examples:
    # Build the container image
    $(basename "$0") build --ros humble

    # Build without cache and just show the command
    $(basename "$0") build --no-cache --dump

    # Run a container with custom name
    $(basename "$0") run -n rookie-test

    # Run and just show the docker command
    $(basename "$0") run --dump
EOF
}

function handle_error()
{
    exit_code="${1:?}"
    error_msg="${2:-}"

    if [[ "${exit_code}" -eq 0 ]]; then
        return 0
    else
        echo "ERR: ${error_msg:-}"
        exit 1
    fi
}

function dont_run_in_container()
{
    if [[ -f "/.dockerenv" ]]; then
        echo "Don't run this script inside a docker container, man"
        return 1
    fi
}

function run_container()
{
    dont_run_in_container; handle_error $?

    local workspace_dir="/home/${USERNAME}/workspace"

    args=(
        --name "${CONTAINER_NAME:?}"
        -it
        --rm
        --privileged
        --user "${UID}"
        --volume "${PWD}/src:${workspace_dir}"
        --volume "${PWD}/.vscode:${workspace_dir}/.vscode"
        --volume /dev/bus/usb:/dev/bus/usb
        --volume "${HOME}/.ssh:${HOME}/.ssh"
        --volume /dev/serial/by-id/:/dev/serial/by-id/
        --device-cgroup-rule='c 188:* rmw'
        --workdir "/home/${USERNAME}/"
        --env "TERM=xterm-256color"
        --env "DISPLAY"
        --env "CONTAINER_NAME=${CONTAINER_NAME:?}"
        --env "RCUTILS_COLORIZED_OUTPUT=1"
        --net=host
    )

    # If we're just dumping the command, we're done here
    if [[ "${DUMP}" == 1 ]]; then
        echo "docker run ${args[*]}"
        return 0
    fi

    docker run "${args[@]}" "${CONTAINER_IMG:?}":latest

}

function setup()
{
    local hooks_src="${SCRIPT_DIR}/hooks"
    local hooks_dst="${SCRIPT_DIR}/.git/hooks"

    local hook_deps=(
        clang-format
        shellcheck
    )

    echo "* Checking hook dependencies ---"
    local missing=0
    for dep in "${hook_deps[@]}"; do
        if ! command -v "${dep}" &>/dev/null; then
            echo "  missing: ${dep}"
            missing=1
        fi
    done
    if [[ "${missing}" -ne 0 ]]; then
        echo "ERR: install missing dependencies before running setup"
        return 1
    fi

    local hooks=(
        pre-commit
    )

    echo "* Installing git hooks"
    for hook in "${hooks[@]}"; do
        cp "${hooks_src}/${hook}" "${hooks_dst}/${hook}"
        chmod +x "${hooks_dst}/${hook}"
        echo "  installed: ${hook}"
    done
}

function build_container()
{
    dont_run_in_container; handle_error $?

    args=(
        --tag "${CONTAINER_IMG:?}:latest"
        --build-arg USER="${USERNAME}"
        --build-arg UID="${UID}"
        --build-arg ROS_DISTRO="${ROS_DISTRO:?}"
        -f docker/dev.Dockerfile
    )

    if [[ "${NO_CACHE:?}" -eq "1" ]]; then
        args+=("--no-cache")
    fi

    # If we're just dumping the command, we're done here
    if [[ "${DUMP:0}" -eq "1" ]]; then
        echo "CMD: docker build ${args[*]} ."
        return 0
    fi

    echo "--- Building ${CONTAINER_IMG:?} image ---"
    docker build "${args[@]}" .
}


while [[ "${#}" -gt 0 ]]; do
    ARG="${1}"
    case "${ARG}" in
        # Verbs
        "setup")
            COMMAND="setup"
            ;;
        "build" | "build-container")
            COMMAND="build_container"
            ;;
        "run" | "run-container")
            COMMAND="run_container"
            ;;
        "help" | "-h" | "--help")
            usage
            exit 0
            ;;
        # Options
        "--dump" | "--dump-command")
            DUMP=1
            ;;
        "-i" | "--image")
            CONTAINER_IMG="${2:?\
                "Must provide an image name for the --image flag"}"
            shift
            ;;
        "-n" | "--name")
            CONTAINER_NAME="${2:?\
                "Must provide a container name for the --name flag"}"
            shift
            ;;
        "--no-cache")
            NO_CACHE=1
            ;;
        "--ros" | "--ros-distro")
            ROS_DISTRO="${2:?\
                "Must provide a ROS distro for the --ros-distro flag"}"
            shift
            ;;
        # Default
        *)
            echo "What? ${ARG}"
            exit 1
    esac
    shift
done

if [[ -n "${COMMAND:-}" ]]; then 
    "${COMMAND}"
else
    usage
fi
